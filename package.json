{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
